{
  "supported_piece_formats": ["slideshow", "mtlk"],
  "layout_piece_type_aliases": {
    "ST": "slideshow"
  },
  "enable_regional_ocr": true,
  "regional_ocr": {
    "max_regions": 8
  },
  "yolo": {
    "enabled": false,
    "model_path": null,
    "conf": 0.25,
    "iou": 0.55,
    "max_det": 30,
    "min_regions_for_use": 2,
    "exclude_ocr_classes": ["product_photo_area"],
    "allow_ocr_classes": [
      "campaign_area",
      "date_area",
      "info_card_area",
      "price_main_area",
      "price_secondary_area",
      "sku_area",
      "promo_badge_area",
      "logo_area"
    ]
  },
  "excel": {
    "header_row_search_limit": 10,
    "max_rows": 5000
  },
  "matching": {
    "min_score": 0.55,
    "min_margin": 0.12
  }
}
